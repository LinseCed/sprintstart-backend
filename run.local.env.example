# Local Spring Boot backend run config
SPRINTSTART_AI_BASE_URL=http://host.docker.internal:8000

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:15432/sprintstart
SPRING_DATASOURCE_USERNAME=sprintstart
SPRING_DATASOURCE_PASSWORD=change-me
GITHUB_PAT=PERSONAL_GITHUB_ACCESS_TOKEN

SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8081/auth/realms/sprintstart
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://localhost:8081/auth/realms/sprintstart/protocol/openid-connect/certs
SPRINTSTART_KEYCLOAK_ADMIN_BASE_URL=http://localhost:8081/auth
SPRINTSTART_KEYCLOAK_ADMIN_REALM=sprintstart
SPRINTSTART_KEYCLOAK_ADMIN_TOKEN_REALM=master
SPRINTSTART_KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
SPRINTSTART_KEYCLOAK_ADMIN_USERNAME=admin
SPRINTSTART_KEYCLOAK_ADMIN_PASSWORD=change-me

SPRINTSTART_KEYCLOAK_SHARED_SECRET=change-me
